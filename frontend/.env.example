# Vite 环境变量配置
# 复制为 .env 用于本地开发，复制为 .env.production 用于生产构建

# 后端 API 地址（部署到 Render/云服务器时必填）
# 本地开发时留空（使用 Vite proxy）
VITE_API_BASE_URL=

# 前端 base 路径（GitHub Pages 项目页面需要设置为 /仓库名/）
# 本地开发保持默认 /
VITE_BASE_PATH=/

# 示例（生产环境）：
# VITE_API_BASE_URL=https://smart-battle-report-backend.onrender.com
# VITE_BASE_PATH=/smart-battle-report/
